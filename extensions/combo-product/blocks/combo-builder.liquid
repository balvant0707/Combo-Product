<style>
  .page-width { padding: 0 0.5rem !important; }
</style>

<div
  id="combo-builder-widget-{{ block.id }}"
  class="combo-builder-root"
  data-shop="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
  data-cb-instance="{{ block.id }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-api-base="https://combo-product-ten.vercel.app"
  data-layout-mode="{{ block.settings.layout_mode | default: 'grid' }}"
  data-enable-sticky-cart="{{ block.settings.enable_sticky_cart | default: true, allow_false: true }}"
  data-cart-btn-label="{{ block.settings.cart_btn_label | default: 'Add To Cart' | escape }}"
  data-checkout-btn-label="{{ block.settings.checkout_btn_label | default: 'Checkout' | escape }}"
  data-step1-label="{{ block.settings.step1_label | default: 'Select Box' | escape }}"
  data-step2-label="{{ block.settings.step2_label | default: 'Pick Items' | escape }}"
  data-step3-label="{{ block.settings.step3_label | default: 'Add to Cart' | escape }}"
  data-step1-heading="{{ block.settings.step1_heading | default: 'Step 1: Select your box' | escape }}"
  data-step2-heading="{{ block.settings.step2_heading | default: 'Step 2: Select your products' | escape }}"
  data-step3-heading="{{ block.settings.step3_heading | default: 'Step 3: Complete your order' | escape }}"
  data-step3-buttons="{{ block.settings.step3_buttons | default: 'both' }}"
  {% if block.settings.box_filter == 'specific' and block.settings.box_names != blank %}
  data-visible-boxes="{{ block.settings.box_names }}"
  {% endif %}
  data-page-template="{{ template.name }}"
  {% case template.name %}
    {% when 'page' %}
    data-page-handle="page:{{ page.handle }}"
    {% when 'product' %}
    data-page-handle="product:{{ product.handle }}"
    {% when 'collection' %}
    data-page-handle="collection:{{ collection.handle }}"
    {% when 'index' %}
    data-page-handle="index"
    {% else %}
    data-page-handle="{{ template.name }}"
  {% endcase %}
  data-product-handle="{{ product.handle }}"
  {{ block.shopify_attributes }}
>
  <div class="combo-builder-loading">
    <div class="spinner-square">
      <div class="square-1 square"></div>
      <div class="square-2 square"></div>
      <div class="square-3 square"></div>
    </div>
  </div>
</div>

<script>
  window.__COMBO_BUILDER__ = window.__COMBO_BUILDER__ || [];
  window.__COMBO_BUILDER__.push({
    mountId:        'combo-builder-widget-{{ block.id }}',
    shop:           '{{ shop.permanent_domain }}',
    currency:       '{{ cart.currency.iso_code }}',
    currencySymbol: '{{ cart.currency.symbol }}',
    apiBase:        'https://combo-product-ten.vercel.app',
    productHandle:  '{{ product.handle }}',
    layoutMode:        '{{ block.settings.layout_mode | default: "grid" }}',
    enableStickyCart:  {{ block.settings.enable_sticky_cart | default: true, allow_false: true | json }},
    cartBtnLabel:      '{{ block.settings.cart_btn_label | default: "Add To Cart" | escape }}',
    checkoutBtnLabel:  '{{ block.settings.checkout_btn_label | default: "Checkout" | escape }}',
    step1Label:        '{{ block.settings.step1_label | default: "Select Box" | escape }}',
    step2Label:     '{{ block.settings.step2_label | default: "Pick Items" | escape }}',
    step3Label:     '{{ block.settings.step3_label | default: "Add to Cart" | escape }}',
    step1Heading:   '{{ block.settings.step1_heading | default: "Step 1: Select your box" | escape }}',
    step2Heading:   '{{ block.settings.step2_heading | default: "Step 2: Select your products" | escape }}',
    step3Heading:   '{{ block.settings.step3_heading | default: "Step 3: Complete your order" | escape }}',
    step3Buttons:   '{{ block.settings.step3_buttons | default: "both" }}'{% if block.settings.box_filter == 'specific' and block.settings.box_names != blank %},
    visibleBoxes:   '{{ block.settings.box_names | escape }}'{% endif %}
  });
</script>

{% schema %}
{
  "name": "Combo Builder",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Product Selection Layout",
      "info": "Grid shows all products at once. Steps guides the customer one item at a time.",
      "options": [
        { "value": "grid", "label": "Grid (all at once)" },
        { "value": "steps", "label": "Steps (one at a time)" }
      ],
      "default": "grid"
    },
    {
      "type": "checkbox",
      "id": "enable_sticky_cart",
      "label": "sticky cart",
      "info": "Shows the sticky cart bar at the bottom while building the combo.",
      "default": false
    },
    {
      "type": "select",
      "id": "box_filter",
      "label": "Show boxes",
      "options": [
        { "value": "all",      "label": "All boxes" },
        { "value": "specific", "label": "Specific box(es)" }
      ],
      "default": "all"
    },
    {
      "type": "text",
      "id": "box_names",
      "label": "Box(es) — name or ID (Example Box ID 12345,56412)",
      "placeholder": "Example Box ID 12345,56412"
    },
    {
      "type": "header",
      "content": "Button Labels (Steps layout only)"
    },
    {
      "type": "select",
      "id": "step3_buttons",
      "label": "Show buttons",
      "options": [
        { "value": "both",          "label": "Add to Cart + Checkout" },
        { "value": "cart_only",     "label": "Add to Cart only" },
        { "value": "checkout_only", "label": "Checkout only" }
      ],
      "default": "both"
    },
    {
      "type": "text",
      "id": "cart_btn_label",
      "label": "Add to Cart button text",
      "default": "Add To Cart",
      "placeholder": "Add To Cart"
    },
    {
      "type": "text",
      "id": "checkout_btn_label",
      "label": "Checkout button text",
      "default": "Checkout",
      "placeholder": "Checkout"
    },
    {
      "type": "header",
      "content": "Step Labels (Steps layout only)"
    },
    {
      "type": "text",
      "id": "step1_label",
      "label": "Step 1 label",
      "default": "Select Box",
      "placeholder": "Select Box"
    },
    {
      "type": "text",
      "id": "step2_label",
      "label": "Step 2 label",
      "default": "Pick Items",
      "placeholder": "Pick Items"
    },
    {
      "type": "text",
      "id": "step3_label",
      "label": "Step 3 label",
      "default": "Add to Cart",
      "placeholder": "Add to Cart"
    },
    {
      "type": "header",
      "content": "Step Headings (Steps layout only)"
    },
    {
      "type": "text",
      "id": "step1_heading",
      "label": "Step 1 heading",
      "default": "Select your box",
      "placeholder": "Select your box"
    },
    {
      "type": "text",
      "id": "step2_heading",
      "label": "Step 2 heading",
      "default": "Select your products",
      "placeholder": "Select your products"
    },
    {
      "type": "text",
      "id": "step3_heading",
      "label": "Step 3 heading",
      "default": "Complete your order",
      "placeholder": "Complete your order"
    }
  ]
}
{% endschema %}
