<div
  id="combo-builder-widget-{{ block.id }}"
  class="combo-builder-root"
  data-shop="{{ shop.permanent_domain }}"
  data-block-id="{{ block.id }}"
  data-cb-instance="{{ block.id }}"
  data-currency="{{ cart.currency.iso_code }}"
  data-currency-symbol="{{ cart.currency.symbol }}"
  data-api-base="https://combo-products.vercel.app"
  data-max-boxes-visible="{{ block.settings.max_boxes_visible }}"
  data-show-box-count="{{ block.settings.show_box_count }}"
  data-show-all-label="{{ block.settings.show_all_btn_label | escape }}"
  {% if block.settings.section_heading != blank %}
  data-heading="{{ block.settings.section_heading | escape }}"
  {% endif %}
  {% if block.settings.show_on_product_page %}
  data-product-handle="{{ product.handle }}"
  {% endif %}
  style="
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
    {% if block.settings.bg_color != blank %}background-color: {{ block.settings.bg_color }};{% endif %}
  "
  {{ block.shopify_attributes }}
>
  <div class="combo-builder-loading">
    <div class="combo-builder-spinner"></div>
    <span>Loading combo builder…</span>
  </div>
</div>

{{- 'combo-builder.css' | asset_url | stylesheet_tag -}}

<script>
  window.__COMBO_BUILDER__ = window.__COMBO_BUILDER__ || [];
  window.__COMBO_BUILDER__.push({
    mountId:          'combo-builder-widget-{{ block.id }}',
    shop:             '{{ shop.permanent_domain }}',
    currency:         '{{ cart.currency.iso_code }}',
    currencySymbol:   '{{ cart.currency.symbol }}',
    apiBase:          'https://combo-products.vercel.app',
    productHandle:    '{{ product.handle }}',
    heading:          '{{ block.settings.section_heading | escape }}',
    maxBoxesVisible:  {{ block.settings.max_boxes_visible }},
    showBoxCount:     {{ block.settings.show_box_count }},
    showAllLabel:     '{{ block.settings.show_all_btn_label | escape }}'
  });
</script>
<script defer src="{{ 'combo-builder.js' | asset_url }}"></script>

{% schema %}
{
  "name": "Combo Builder",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_heading",
      "label": "Section heading",
      "default": "Build Your Combo"
    },
    {
      "type": "checkbox",
      "id": "show_on_product_page",
      "label": "Show on product page",
      "default": true
    },
    {
      "type": "header",
      "content": "Box Display"
    },
    {
      "type": "range",
      "id": "max_boxes_visible",
      "label": "Max boxes shown initially",
      "min": 1,
      "max": 50,
      "step": 1,
      "default": 50,
      "info": "Set to 50 to always show all boxes. Reduce to clip and show a 'View all' button."
    },
    {
      "type": "checkbox",
      "id": "show_box_count",
      "label": "Show total box count",
      "default": true,
      "info": "Displays '4 combo boxes available' above the grid"
    },
    {
      "type": "text",
      "id": "show_all_btn_label",
      "label": "\"Show all\" button label",
      "default": "View all"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color"
    }
  ]
}
{% endschema %}
