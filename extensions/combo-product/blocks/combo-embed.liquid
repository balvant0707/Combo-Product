{% if block.settings.enabled %}
{{- 'combo-builder.css' | asset_url | stylesheet_tag -}}
<script defer src="{{ 'combo-builder.js' | asset_url }}"></script>
<script>
  window.__COMBO_BUILDER_GLOBAL__ = {
    shop:           '{{ shop.permanent_domain }}',
    currency:       '{{ cart.currency.iso_code }}',
    currencySymbol: '{{ cart.currency.symbol }}',
    apiBase:        'https://combo-products.vercel.app'
  };
</script>
{% endif %}

{% schema %}
{
  "name": "Combo Builder",
  "target": "body",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "Enable Combo Builder",
      "default": true,
      "info": "Load Combo Builder scripts and styles across your storefront."
    }
  ]
}
{% endschema %}
