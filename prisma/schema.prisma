generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?   @db.Text
  expires             DateTime?
  accessToken         String    @db.Text
  userId              BigInt?
  firstName           String?   @db.Text
  lastName            String?   @db.Text
  email               String?   @db.Text
  accountOwner        Boolean   @default(false)
  locale              String?   @db.Text
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?   @db.Text
  refreshTokenExpires DateTime?

  @@map("session")
}

model shop {
  id                      Int       @id @default(autoincrement())
  shop                    String    @unique(map: "Shop_shop_key")
  accessToken             String?
  installed               Boolean   @default(false)
  status                  String?   @default("installed") @db.VarChar(32)
  ownerName               String?   @db.VarChar(255)
  email                   String?   @db.VarChar(320)
  contactEmail            String?   @db.VarChar(320)
  name                    String?   @db.VarChar(255)
  country                 String?   @db.VarChar(100)
  city                    String?   @db.VarChar(100)
  currency                String?   @db.VarChar(10)
  phone                   String?   @db.VarChar(50)
  primaryDomain           String?   @db.VarChar(255)
  plan                    String?   @db.VarChar(100)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  onboardedAt             DateTime?
  uninstalledAt           DateTime?
  announcementEmailSentAt DateTime?
  reviewPromptDelayDays   Int       @default(7)
  reviewPopupDismissedAt  DateTime?
  reviewSubmittedAt       DateTime?
  reviewRating            Int?
  reviewComment           String?   @db.Text
}

model uninstallfeedback {
  id                  Int       @id @default(autoincrement())
  shop                String    @db.VarChar(255)
  ownerName           String?   @db.VarChar(255)
  email               String?   @db.VarChar(320)
  contactEmail        String?   @db.VarChar(320)
  feedbackText        String?   @db.Text
  feedbackToken       String?   @unique @db.VarChar(128)
  feedbackSubmittedAt DateTime?
  uninstalledAt       DateTime  @default(now())

  @@index([shop], map: "UninstallFeedback_shop_idx")
}

model feedbackmsg {
  id           Int      @id @default(autoincrement())
  feedbackText String   @db.Text
  createdAt    DateTime @default(now())
}

model ComboBox {
  id                      Int               @id @default(autoincrement())
  shop                    String
  boxName                 String            @db.VarChar(255)
  displayTitle            String            @db.VarChar(255)
  comboProductButtonTitle String?           @db.VarChar(100)
  productButtonTitle      String?           @db.VarChar(100)
  itemCount               Int               @default(1)
  bundlePrice             Decimal           @db.Decimal(10, 2)
  bundlePriceType         String            @default("manual") @db.VarChar(10)
  isGiftBox               Boolean           @default(false)
  allowDuplicates         Boolean           @default(false)
  bannerImageUrl          String?           @db.VarChar(500)
  sortOrder               Int               @default(0)
  isActive                Boolean           @default(true)
  giftMessageEnabled      Boolean           @default(false)
  shopifyProductId        String?           @db.VarChar(255)
  shopifyVariantId        String?           @db.VarChar(255)
  shopifyDiscountId       String?           @db.VarChar(255)
  deletedAt               DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  bannerImageData         Bytes?            @db.MediumBlob
  bannerImageFileName     String?           @db.VarChar(255)
  bannerImageMimeType     String?           @db.VarChar(100)
  comboStepsConfig        String?           @map("combo_steps_config") @db.LongText
  scopeType               String            @default("specific_collections") @db.VarChar(30)
  scopeItemsJson          String?           @db.LongText
  pageHandle              String?           @db.VarChar(255)
  boxCode                 String?           @unique @db.VarChar(10)
  orders                  BundleOrder[]
  products                ComboBoxProduct[]
  config                  ComboBoxConfig?
  stepImages              ComboStepImage[]

  @@index([shop])
  @@map("combo_box")
}

model ComboBoxConfig {
  id                 Int      @id @default(autoincrement())
  boxId              Int      @unique
  comboType          Int      @default(2)
  title              String?  @db.VarChar(255)
  subtitle           String?  @db.VarChar(255)
  bundlePrice        Decimal? @db.Decimal(10, 2)
  bundlePriceType    String?  @default("manual") @db.VarChar(10)
  isActive           Boolean  @default(true)
  isGiftBox          Boolean  @default(false)
  allowDuplicates    Boolean  @default(false)
  giftMessageEnabled Boolean  @default(false)
  showProductImages  Boolean  @default(true)
  showProgressBar    Boolean  @default(true)
  allowReselection   Boolean  @default(true)
  stepsJson          String?  @db.LongText
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  box                ComboBox @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@map("combo_box_config")
}

model ComboStepImage {
  id        Int      @id @default(autoincrement())
  boxId     Int
  stepIndex Int
  imageData Bytes?   @db.MediumBlob
  mimeType  String?  @db.VarChar(100)
  fileName  String?  @db.VarChar(255)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  box       ComboBox @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@unique([boxId, stepIndex])
  @@map("combo_step_image")
}

model ComboBoxProduct {
  id              Int      @id @default(autoincrement())
  boxId           Int
  productId       String   @db.VarChar(255)
  productTitle    String?  @db.VarChar(255)
  productImageUrl String?  @db.VarChar(500)
  productHandle   String?  @db.VarChar(255)
  isCollection    Boolean  @default(false)
  variantIds      String?  @db.LongText
  createdAt       DateTime @default(now())
  productPrice    Decimal? @db.Decimal(10, 2)
  box             ComboBox @relation(fields: [boxId], references: [id], onDelete: Cascade)

  @@index([boxId])
  @@map("combo_box_product")
}

model BundleOrder {
  id               Int      @id @default(autoincrement())
  shop             String
  orderId          String   @db.VarChar(255)
  orderName        String?  @db.VarChar(64)
  orderNumber      Int?
  boxId            Int
  selectedProducts String   @db.LongText
  bundlePrice      Decimal  @db.Decimal(10, 2)
  giftMessage      String?  @db.Text
  orderDate        DateTime
  customerId       String?  @db.VarChar(255)
  createdAt        DateTime @default(now())
  box              ComboBox @relation(fields: [boxId], references: [id])

  @@index([shop])
  @@index([boxId])
  @@map("bundle_order")
}

model AppSettings {
  id                 Int      @id @default(autoincrement())
  shop               String   @unique
  widgetHeadingText  String?  @db.VarChar(255)
  ctaButtonLabel     String?  @db.VarChar(100)
  addToCartLabel     String?  @db.VarChar(100)
  buttonColor        String?  @default("#2A7A4F") @db.VarChar(20)
  activeSlotColor    String?  @default("#2A7A4F") @db.VarChar(20)
  showSavingsBadge   Boolean  @default(false)
  allowDuplicates    Boolean  @default(false)
  showProductPrices  Boolean  @default(false)
  forceShowOos       Boolean  @default(false)
  giftMessageField   Boolean  @default(false)
  analyticsTracking  Boolean  @default(true)
  emailNotifications Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  presetTheme        String?  @default("custom") @db.VarChar(50)
  widgetMaxWidth     Int?     @default(1140)
  productCardsPerRow Int?     @default(4)

  @@map("app_settings")
}

model Subscription {
  id               String    @id @default(uuid()) @db.VarChar(36)
  shop             String    @unique @db.VarChar(255)
  plan             String    @default("FREE") @db.VarChar(20)
  status           String    @default("NONE") @db.VarChar(20)
  subscriptionId   String?   @db.VarChar(255)
  trialEndsAt      DateTime?
  currentPeriodEnd DateTime?
  freeActivatedAt  DateTime?
  planStartedAt    DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([shop])
  @@map("subscription")
}
